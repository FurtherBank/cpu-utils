{
  "name": "@cpu-utils/headless",
  "version": "1.2.0",
  "description": "Headless browser utilities for the monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "tsc -p tsconfig.test.json && node --test --experimental-test-module-mocks dist/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chrome-cookies-secure": "^3.0.1",
    "keytar": "^7.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "*"
  }
}
